# ============================================================
# Sistema de Turnos — Variables de entorno (ejemplo)
# Copiá este archivo a .env y ajustá los valores antes de levantar:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Entorno
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# Infraestructura (Traefik / puertos host)
# ------------------------------------------------------------
HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
DB_ROOT_PASSWORD=secret
DB_PORT_HOST=3308

# ------------------------------------------------------------
# Base de datos — microservicios (red interna Docker)
# ------------------------------------------------------------
DB_HOST=turnos_mysql
DB_PORT=3306
DB_USER=root
DB_DIALECT=mysql
DB_NAME_CLIENTES=turnos

# ------------------------------------------------------------
# Autenticación inter-servicio (Basic Auth + firma JWT)
# ------------------------------------------------------------
AUTH_BASIC_USER=turnos
AUTH_BASIC_PW=cambiar
SECRET_KEY=cambiar-este-valor-por-una-cadena-larga-y-aleatoria-de-al-menos-64-chars

# ------------------------------------------------------------
# Servicio AUTH (autenticación JWT + base turnos_auth)
# ------------------------------------------------------------
AUTH_API_URL=http://turnos_auth
DB_HOST_AUTH=turnos_mysql
DB_PORT_AUTH=3306
DB_USER_AUTH=root
DB_ROOT_PASSWORD_AUTH=secret
DB_NAME_AUTH=turnos_auth
ADMIN_EMAIL=admin@turnos.local
ADMIN_PASSWORD=Admin1234!

# ------------------------------------------------------------
# Envío de emails SMTP (lo maneja el servicio AUTH)
# ------------------------------------------------------------
MAILER_SMTP_HOST=smtp.example.com
MAILER_SMTP_PORT=587
MAILER_SMTP_SECURE=false
MAILER_USER=usuario@example.com
MAILER_PASSWORD=cambiar
MAILER_FROM_EMAIL=no-reply@turnos.local
MAILER_FROM_NAME=Sistema de Turnos

# ------------------------------------------------------------
# Servicio STORAGE / MinIO (adjuntos clínicos)
# ------------------------------------------------------------
MINIO_ENDPOINT=turnos_minio
MINIO_ENDPOINT_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=turnos
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_MAX_SIZE_MB=50

# ------------------------------------------------------------
# URLs de microservicios (consumidas por el backoffice)
# ------------------------------------------------------------
TURNOS_MS_AGENDA_URL=http://turnos_ms_agenda
TURNOS_MS_CLINICA_URL=http://turnos_ms_clinica
TURNOS_MS_INTEGRACIONES_URL=http://turnos_ms_integraciones
TURNOS_MS_PAGOS_URL=http://turnos_ms_pagos
TURNOS_MS_USUARIOS_URL=http://turnos_ms_usuarios
TURNOS_MS_WIDGET_URL=http://turnos_ms_widget

# ------------------------------------------------------------
# Web / CORS
# ------------------------------------------------------------
WEB_URL=http://turnos.localhost
CORS_ALLOWED_ORIGINS=http://turnos.localhost

# ------------------------------------------------------------
# Integraciones (opcionales — dejar vacías si no se usan)
# ------------------------------------------------------------
# Google Calendar (OAuth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# MercadoPago (pagos)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
