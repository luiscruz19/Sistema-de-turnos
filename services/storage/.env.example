# ============================================================
# Storage microservice — environment variables reference
# Copy to .env and fill in real values before starting.
# ============================================================

# --- App ---
MINIO_APP_PORT=80
NODE_ENV=development
MINIO_INITIAL_ROUTE=/storage

# --- MinIO connection ---
MINIO_ENDPOINT=minio
MINIO_ENDPOINT_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=mi-app
MINIO_USE_SSL=false
# Internal URL used to build public file URLs (e.g. http://minio:9000)
MINIO_PRIVATE_URL=http://minio:9000

# --- Basic Auth (service-to-service) ---
AUTH_BASIC_USER=storage
AUTH_BASIC_PW=secret

# --- Microservices ---
# Supports both USUARIOS_API_URL and ADMINISTRADORES_API_URL (USUARIOS takes priority)
USUARIOS_API_URL=http://usuarios
# ADMINISTRADORES_API_URL=http://administradores

# --- CORS ---
WEB_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting (POST /upload only) ---
STORAGE_RATE_LIMIT_WINDOW_MS=60000
STORAGE_RATE_LIMIT_MAX=50

# --- Upload processing ---
STORAGE_MAX_SIZE_MB=500
STORAGE_OUTPUT_FORMAT=webp
STORAGE_MAX_WIDTH=1920
STORAGE_QUALITY=85
STORAGE_THUMBNAIL_WIDTH=300
STORAGE_THUMBNAIL_HEIGHT=300

# --- Antivirus (optional — requires clamav) ---
STORAGE_ENABLE_AV_SCAN=false
# When true, uploads are rejected if clamscan is unavailable or fails.
STORAGE_AV_FAIL_CLOSED=true

# --- QR code generation (optional) ---
STORAGE_ENABLE_QR=false

# --- Blocked types (comma-separated, no spaces) ---
# Additional MIME types to block on top of the built-in list.
STORAGE_BLOCKED_MIME_TYPES=
# Additional extensions to block (with or without leading dot).
STORAGE_BLOCKED_EXTENSIONS=.php,.exe,.sh,.bat

# --- JWT / internal secret ---
# Used for inter-service token validation. Change this in every environment.
SECRET_KEY=changeme
